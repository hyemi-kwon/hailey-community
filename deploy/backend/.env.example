DOCKER_HUB_ID=your-dockerhub-id/hailey-community
IMAGE_TAG=commit-sha
BACKEND_PORT=8090
SPRING_DATASOURCE_URL=jdbc:mysql://database-private-host:3306/hailey?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul
SPRING_DATASOURCE_USERNAME=replace-me
SPRING_DATASOURCE_PASSWORD=replace-me
CORS_ALLOWED_ORIGINS=https://hailey.my
SESSION_COOKIE_SECURE=true
JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m -Duser.timezone=Asia/Seoul
