# Copy to /home/ubuntu/hailey-community/.env on EC2 and replace every placeholder.
DOCKER_HUB_ID=your-dockerhub-id/hailey-community
IMAGE_TAG=commit-sha
MYSQL_DATABASE=hailey
MYSQL_ROOT_PASSWORD=replace-me
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=replace-me
FRONTEND_PORT=8080
API_BASE_URL=https://api.hailey.my
CORS_ALLOWED_ORIGINS=https://hailey.my
SESSION_COOKIE_SECURE=true
